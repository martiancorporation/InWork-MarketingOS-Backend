# PRODUCTION.
# Loaded when APP_ENV=production.
#
# IMPORTANT: in production, inject these as real OS environment variables or via
# a secrets manager (AWS/GCP Secrets Manager, Vault, k8s Secrets). Do NOT write
# real secrets into a committed file. This template documents what must be set.
#
# The app REFUSES TO START in production if SECRET_KEY is the dev placeholder.

APP_ENV=production
DEBUG=false

# Managed Postgres (use SSL, e.g. append ?sslmode=require). Provided as a secret.
DATABASE_URL=
DATABASE_ECHO=false

# Strong, unique secret — 48+ random bytes. Provided as a secret.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Exact production frontend origin(s) only — no wildcards.
CORS_ORIGINS=https://app.inwork.example

# Production Anthropic credentials.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Third-party OAuth (fill the ones you use).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
