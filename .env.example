# ============================================================================
# CANONICAL REFERENCE — every supported variable, with safe placeholder values.
# ============================================================================
# You normally do NOT copy this file directly. Instead copy the template for
# your environment:
#     cp .env.local.example       .env.local          # local dev
#     cp .env.development.example .env.development     # shared dev server
#     cp .env.production.example  .env.production      # production
#
# The app loads `.env` then `.env.$APP_ENV` (the latter wins); real OS env vars
# override both. All `.env*` files are git-ignored — never commit real secrets.
# Names only here — no real secrets.

# ---- Application ----
APP_NAME=InWork MarketingOS API
APP_ENV=local                 # local | development | production
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ---- Security / Auth ----
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/inwork
DATABASE_ECHO=false           # log SQL statements (noisy — dev only)

# ---- Anthropic (Claude) — optional; onboarding AI degrades gracefully if unset ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024

# ---- Object storage / file uploads (Amazon S3) ----
# Upload endpoints return 503 until a bucket + region are set.
STORAGE_PROVIDER=s3
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
# Leave credentials blank in production to use the task/instance IAM role.
STORAGE_AWS_ACCESS_KEY_ID=
STORAGE_AWS_SECRET_ACCESS_KEY=
# STORAGE_S3_ENDPOINT_URL=http://localhost:4566   # LocalStack / S3-compatible
STORAGE_KEY_PREFIX=uploads
STORAGE_SSE=AES256                 # server-side encryption: AES256 or aws:kms
STORAGE_PRESIGN_EXPIRY_SECONDS=900 # presigned download-URL TTL (15 min)
STORAGE_MAX_UPLOAD_BYTES=20971520  # 20 MB
# Comma-separated allow-list; "*" disables the check. Defaults to docs/images/office.
# STORAGE_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg

# ---- Client intelligence (async profile + RAG) ----
# Runs with NO config: summary + directive rules use the existing ANTHROPIC_API_KEY,
# and semantic retrieval falls back to a built-in local embedder.
# Claude has no embeddings API, so set a Voyage key ONLY to upgrade retrieval to
# production quality. Everything else (model, dim, top_k, enabled) has a code default;
# don't set INTEL_EMBEDDING_DIM here — it's tied to the DB column + a migration.
# INTEL_VOYAGE_API_KEY=
# INTEL_ENABLED=false          # kill-switch: skip the whole pipeline

# ---- Google (OAuth / GA4 / Search Console / Ads / LSA) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ---- Meta Business ----
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# ---- LinkedIn Ads ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
