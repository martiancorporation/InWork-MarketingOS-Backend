# Copy this file to `.env` and fill in real values locally.
# `.env` is git-ignored and must NEVER be committed. Names only here — no secrets.

# ---- Application ----
APP_NAME=InWork MarketingOS API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ---- Security / Auth ----
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database ----
DATABASE_URL=

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Google (OAuth / GA4 / Search Console / Ads / LSA) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ---- Meta Business ----
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# ---- LinkedIn Ads ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
