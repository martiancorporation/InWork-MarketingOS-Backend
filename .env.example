# ============================================================================
# CANONICAL REFERENCE — every supported variable, with safe placeholder values.
# ============================================================================
# You normally do NOT copy this file directly. Instead copy the template for
# your environment:
#     cp .env.local.example       .env.local          # local dev
#     cp .env.development.example .env.development     # shared dev server
#     cp .env.production.example  .env.production      # production
#
# The app loads `.env` then `.env.$APP_ENV` (the latter wins); real OS env vars
# override both. All `.env*` files are git-ignored — never commit real secrets.
# Names only here — no real secrets.

# ---- Application ----
APP_NAME=InWork MarketingOS API
APP_ENV=local                 # local | development | production
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ---- Security / Auth ----
# Generate a strong key (>=32 chars, enforced):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Explicit origins only — '*' is rejected (incompatible with credentialed CORS).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# In-process rate limiting on sensitive routes (login, paid-AI). Per-worker.
RATE_LIMIT_ENABLED=true

# ---- Database ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/inwork
DATABASE_ECHO=false           # log SQL statements (noisy — dev only)
# Connection pool (per process). (POOL_SIZE + MAX_OVERFLOW) × workers must stay
# under the DB/pooler connection ceiling.
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ---- Anthropic (Claude) — optional; onboarding AI degrades gracefully if unset ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_SECONDS=30    # per-request timeout
ANTHROPIC_MAX_RETRIES=2         # SDK retries on 429/5xx (exponential backoff)

# ---- Cross-provider QA (second provider independently reviews generated output) ----
# A DIFFERENT vendor QAs Anthropic's output to counter single-vendor bias. Off by
# default; when enabled it runs only if the chosen provider is configured, and
# otherwise degrades to a clean "not_reviewed" passthrough.
AI_QA_ENABLED=false             # master switch for the QA pass
AI_QA_PROVIDER=openai           # which provider reviews: openai | anthropic

# ---- OpenAI-compatible provider (used as the QA reviewer) ----
# Any OpenAI-compatible Chat Completions endpoint works via OPENAI_BASE_URL
# (OpenAI, Azure OpenAI, local gateways). Leave the key blank to keep QA off.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini        # a cheap reviewer by default
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT_SECONDS=30

# ---- Object storage / file uploads (Amazon S3) ----
# Upload endpoints return 503 until a bucket + region are set.
STORAGE_PROVIDER=s3
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
# Leave credentials blank in production to use the task/instance IAM role.
STORAGE_AWS_ACCESS_KEY_ID=
STORAGE_AWS_SECRET_ACCESS_KEY=
# STORAGE_S3_ENDPOINT_URL=http://localhost:4566   # LocalStack / S3-compatible
STORAGE_KEY_PREFIX=uploads
STORAGE_SSE=AES256                 # server-side encryption: AES256 or aws:kms
STORAGE_PRESIGN_EXPIRY_SECONDS=900 # presigned download-URL TTL (15 min)
STORAGE_MAX_UPLOAD_BYTES=20971520  # 20 MB
# Comma-separated allow-list; "*" disables the check. Defaults to docs/images/office.
# STORAGE_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg

# ---- Client intelligence (async profile + RAG) ----
# Runs with NO config: summary + directive rules use the existing ANTHROPIC_API_KEY,
# and semantic retrieval falls back to a built-in local embedder.
# Claude has no embeddings API, so set a Voyage key ONLY to upgrade retrieval to
# production quality. Everything else (model, dim, top_k, enabled) has a code default;
# don't set INTEL_EMBEDDING_DIM here — it's tied to the DB column + a migration.
# INTEL_VOYAGE_API_KEY=
# INTEL_ENABLED=false          # kill-switch: skip the whole pipeline

# ---- Scheduler cadence (python -m app.scheduler) ----
# How often each platform-wide sweep fires. Defaults shown; override per env.
# SCHEDULER_TICK_SECONDS=30
# SCHEDULER_WATCHDOG_INTERVAL_MINUTES=60          # KPI watchdog "refresh" loop
# SCHEDULER_INTEGRATION_SYNC_INTERVAL_MINUTES=360
# SCHEDULER_DIGEST_INTERVAL_MINUTES=1440          # daily
# SCHEDULER_DIGEST_ENABLED=true

# ---- Google (OAuth / GA4 / Search Console / Ads / LSA) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Google Ads only: Google-approved developer token + manager (MCC) customer id
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v18

# ---- Meta Business ----
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
# Meta Graph API version + OAuth scopes (sensible defaults; override only if needed)
META_API_VERSION=v21.0
META_SCOPES=ads_read,business_management

# ---- LinkedIn Ads ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# ---- Scraping / research (brand extraction) ----
# ScrapingBee: proxied, JS-rendering page fetch. Preferred fetcher for brand
# extraction when set — gets past anti-bot / geo-IP blocks a same-server render
# or scrape hits. Leave blank to fall back to the headless render / httpx scrape.
SCRAPINGBEE_API_KEY=
# Brave Search API: optional brand research folded into the AI's context.
BRAVE_API_KEY=
