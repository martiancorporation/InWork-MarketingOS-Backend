# LOCAL development on your machine.
#   cp .env.local.example .env.local   # then edit as needed
# Loaded when APP_ENV=local (the default).

APP_ENV=local
DEBUG=true

# Local Postgres (matches docker-compose.yml). Change if you run your own.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/inwork
DATABASE_ECHO=false

# A throwaway dev key is fine locally. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=local-dev-secret-not-for-production-please-change-0123456789
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend dev servers (Vite / Next).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Leave the Anthropic key blank locally — brand extraction uses its safe fallback.
ANTHROPIC_API_KEY=
