# DEVELOPMENT / staging server (shared team environment).
#   cp .env.development.example .env.development   # then fill in real values
# Loaded when APP_ENV=development.
#
# On a real dev server, prefer injecting these as OS env vars / CI secrets
# rather than committing a filled-in file.

APP_ENV=development
DEBUG=true

# Managed dev database — set the real connection string via secret, not here.
DATABASE_URL=
DATABASE_ECHO=false

# Set from your secrets manager / CI.
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# The deployed dev frontend origin(s).
CORS_ORIGINS=https://dev.app.inwork.example

# Real (dev-tier) Anthropic key so AI features are exercised in dev.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
